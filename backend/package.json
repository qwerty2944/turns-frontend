{
  "name": "turns-backend",
  "version": "1.0.0",
  "description": "Colyseus server for board game matchmaking (Love Letter)",
  "type": "module",
  "main": "build/index.js",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "start": "node build/index.js",
